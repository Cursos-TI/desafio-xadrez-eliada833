#include <stdio.h>

int main() {
    // Tema 4 - Movimentação do Cavalo
    // Movimento: 2 casas para Cima + 1 casa para Direita
    // Requisito: loops aninhados for + while
    
    int casas_verticais = 2;   // 2 casas para Cima
    int casas_horizontais = 1; // 1 casa para Direita
    int i, j;
    
    printf("=== Movimentacao do Cavalo ===\n\n");
    
    // FOR externo: controla as 2 casas verticais
    for (i = 0; i < casas_verticais; i++) {
        
        // WHILE interno: imprime cada "Cima"
        // Isso caracteriza loops aninhados exigidos
        j = 0;
        while (j < 1) {
            printf("Cima\n");
            j++;
        }
    } // Fim do for - essa chave que tava faltando
    
    // Movimento horizontal fora do loop aninhado
    // Pode usar outro loop se quiser, mas não é obrigatório
    for (i = 0; i < casas_horizontais; i++) {
        printf("Direita\n");
    }
    
    printf("\n"); // Linha em branco pedida no requisito
    
    return 0;
}
