#include <stdio.h>

int main() {
    // Tema 4 - Movimentação do Cavalo
    // Movimento em "L": 2 casas para Cima + 1 casa para Direita
    // Usando loops aninhados: for + while
    
    int casas_verticais = 2;   // Quantidade de casas para Cima
    int casas_horizontais = 1; // Quantidade de casas para Direita
    int i, j;
    
    printf("=== Movimentacao do Cavalo ===\n");
    printf("Movimento em L: 2 casas para Cima + 1 casa para Direita\n\n");
    
    // Loop FOR externo: controla quantas vezes vamos mover na vertical
    for (i = 1; i <= casas_verticais; i++) {
        
        // Loop WHILE interno: executa o print de cada passo vertical
        // Isso caracteriza os loops aninhados exigidos
        j = 0;
        while (j < 1) {
            printf("Cima\n"); // Saída padrão do requisito
            j++;
        }
    }
    
    // Após terminar as 2 casas para Cima, faz 1 casa para Direita
    // Usando do-while só pra garantir outro tipo de loop
    int passos_direita = 0;
    do {
        printf("Direita\n"); // Saída padrão do requisito
        passos_direita++;
    } while (passos_direita < casas_horizontais);
    
    // Linha em branco para separar dos outros movimentos
    printf("\n");
    
    return 0;
}
